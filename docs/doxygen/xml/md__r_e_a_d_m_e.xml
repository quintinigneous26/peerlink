<sect1 id="md__r_e_a_d_m_e_1autotoc_md299">
<title>🛠️ 配置</title><sect2 id="md__r_e_a_d_m_e_1autotoc_md300">
<title>环境变量</title><para><programlisting filename=".bash"><codeline><highlight class="normal">#<sp/>STUN<sp/>服务器</highlight></codeline>
<codeline><highlight class="normal">STUN_PORT=3478</highlight></codeline>
<codeline><highlight class="normal">STUN_TCP_PORT=3479</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">#<sp/>Relay<sp/>服务器</highlight></codeline>
<codeline><highlight class="normal">RELAY_MIN_PORT=50000</highlight></codeline>
<codeline><highlight class="normal">RELAY_MAX_PORT=50010</highlight></codeline>
<codeline><highlight class="normal">RELAY_MAX_ALLOCATIONS=1000</highlight></codeline>
<codeline><highlight class="normal">RELAY_ALLOCATION_LIFETIME=600</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">#<sp/>信令服务器</highlight></codeline>
<codeline><highlight class="normal">SIGNALING_WS_PORT=8080</highlight></codeline>
<codeline><highlight class="normal">SIGNALING_WSS_PORT=8443</highlight></codeline>
<codeline><highlight class="normal">REDIS_URL=redis://localhost:6379</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">#<sp/>DID<sp/>服务</highlight></codeline>
<codeline><highlight class="normal">DID_SERVICE_PORT=9000</highlight></codeline>
<codeline><highlight class="normal">JWT_SECRET=your-secret-key-change-in-production</highlight></codeline>
