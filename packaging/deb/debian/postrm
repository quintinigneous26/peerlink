#!/bin/bash
set -e

# postrm script for p2p-platform

case "$1" in
    purge)
        # Remove user and group
        if getent passwd p2p > /dev/null; then
            deluser --system p2p || true
        fi
        if getent group p2p > /dev/null; then
            delgroup --system p2p || true
        fi

        # Remove data directories
        rm -rf /var/log/p2p-platform
        rm -rf /var/lib/p2p-platform
        rm -rf /etc/p2p-platform

        echo "P2P Platform purged completely."
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0
