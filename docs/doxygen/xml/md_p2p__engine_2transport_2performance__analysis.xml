<sect1 id="md_p2p__engine_2transport_2performance__analysis_1autotoc_md68">
<title>4. 性能目标</title><para><table rows="5" cols="4"><row>
<entry thead="yes"><para>指标  </para>
</entry><entry thead="yes" align='center'><para>当前  </para>
</entry><entry thead="yes" align='center'><para>目标  </para>
</entry><entry thead="yes" align='center'><para>go-libp2p  </para>
</entry></row>
<row>
<entry thead="no"><para>连接延迟  </para>
</entry><entry thead="no" align='center'><para>~50ms  </para>
</entry><entry thead="no" align='center'><para>&lt;30ms  </para>
