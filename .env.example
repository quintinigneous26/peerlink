# P2P Platform 环境变量配置
# 复制此文件为 .env 并修改相应的值

# ============================================
# STUN 服务器配置
# ============================================
STUN_PORT=3478
STUN_TCP_PORT=3479
STUN_MAX_CONNECTIONS=10000
STUN_BUFFER_SIZE=65536

# ============================================
# Relay 服务器配置
# ============================================
RELAY_MIN_PORT=50000
RELAY_MAX_PORT=50010
RELAY_MAX_ALLOCATIONS=1000
RELAY_ALLOCATION_LIFETIME=600
RELAY_MAX_BANDWIDTH=10485760

# ============================================
# 信令服务器配置
# ============================================
SIGNALING_WS_PORT=8080
SIGNALING_WSS_PORT=8443
SIGNALING_MAX_CONNECTIONS=5000
SIGNALING_HEARTBEAT_INTERVAL=30
SIGNALING_CONNECTION_TIMEOUT=300

# SSL/TLS 证书 (生产环境必须配置)
SIGNALING_SSL_CERT=/etc/ssl/certs/server.crt
SIGNALING_SSL_KEY=/etc/ssl/private/server.key

# ============================================
# DID 服务配置
# ============================================
DID_SERVICE_PORT=9000

# JWT 配置 (生产环境必须修改)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_EXPIRATION=3600
JWT_ALGORITHM=HS256

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD_IN_PRODUCTION
REDIS_DB=0
REDIS_POOL_SIZE=50

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/p2p/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# ============================================
# 监控配置
# ============================================
METRICS_ENABLED=true
METRICS_PORT=9001

# ============================================
# 性能调优
# ============================================
WORKER_THREADS=4
MAX_CONNECTIONS=10000
CONNECTION_TIMEOUT=300
BUFFER_SIZE=65536

# ============================================
# 安全配置
# ============================================
# 启用 HTTPS
ENABLE_HTTPS=false

# CORS 配置
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================
# 开发/调试配置
# ============================================
DEBUG=false
DEVELOPMENT_MODE=false

# ============================================
# 数据库配置 (可选)
# ============================================
# ��果使用 PostgreSQL 替代 Redis
# DATABASE_URL=postgresql://user:password@localhost:5432/p2p_platform

# ============================================
# 备份配置
# ============================================
BACKUP_ENABLED=true
BACKUP_DIR=/backup/p2p-platform
BACKUP_RETENTION_DAYS=30

# ============================================
# 告警配置
# ============================================
ALERT_EMAIL=ops@peerlink-project.io
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 其他配置
# ============================================
TIMEZONE=Asia/Shanghai
LANGUAGE=zh_CN
