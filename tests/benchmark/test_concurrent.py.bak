# ===== 资源使用测试 =====


@pytest.mark.benchmark
class TestResourceUsage:
    """资源使用测试"""

    async def test_memory_per_connection(self, echo_server: dict[str, Any]):
        """
        测试每个连接的内存使用

        目标: 每个连接 < 0.5MB
        """
        host = echo_server["host"]
        port = echo_server["port"]

        # 测试不同连接数的内存使用
        connection_counts = [10, 50, 100]
        memory_per_conn = []

        for count in connection_counts:
            initial_memory = ResourceMonitor.get_memory_usage_mb()

            # 创建连接
            connections = []
            for _ in range(count):
                try:
                    reader, writer = await asyncio.wait_for(
                        asyncio.open_connection(host, port), timeout=5.0
                    )
                    connections.append((reader, writer))
                except (asyncio.TimeoutError, OSError):
                    pass

            # 等待稳定
            await asyncio.sleep(0.5)

            peak_memory = ResourceMonitor.get_memory_usage_mb()
            memory_used = peak_memory - initial_memory
            per_conn = memory_used / len(connections) if connections else 0
            memory_per_conn.append(per_conn)

            print(f"\n{len(connections)} 连接: 总内存 {memory_used:.2f}MB, 每连接 {per_conn:.2f}MB")

            # 清理连接
            for reader, writer in connections:
                writer.close()
                await writer.wait_closed()

            await asyncio.sleep(0.5)

        # 验证内存使用
        avg_per_conn = statistics.mean(memory_per_conn)
        assert (
            avg_per_conn < CONCURRENT_TARGETS["max_memory_per_connection_mb"]
        ), f"每连接内存 {avg_per_conn:.2f}MB 超过目标 {CONCURRENT_TARGETS['max_memory_per_connection_mb']}MB"

    async def test_file_descriptor_usage(self, echo_server: dict[str, Any]):
        """
        测试文件描述符使用

        每个连接应该使用 1 个文件描述符
        """
        initial_fds = ResourceMonitor.get_open_files_count()

        # 创建 50 个连接
        connections = []
        for _ in range(50):
            try:
                reader, writer = await asyncio.wait_for(
                    asyncio.open_connection(
                        echo_server["host"], echo_server["port"]
                    ),
                    timeout=5.0,
                )
                connections.append((reader, writer))
            except (asyncio.TimeoutError, OSError):
                pass

        await asyncio.sleep(0.5)

        final_fds = ResourceMonitor.get_open_files_count()
        fds_used = final_fds - initial_fds

        print(f"\n文件描述符: 初始 {initial_fds}, 最终 {final_fds}, 使用 {fds_used}")

        # 清理
        for reader, writer in connections:
            writer.close()
            await writer.wait_closed()

        # 验证: 每个连接大约使用 1 个文件描述符
        # 允许一些误差 (socket, pipes 等)
        assert fds_used <= len(connections) * 2, f"文件描述符使用过多: {fds_used}"

    async def test_connection_rate(self, echo_server: dict[str, Any]):
        """
        测试连接建立速率

        目标: > 100 连接/秒
        """
        host = echo_server["host"]
        port = echo_server["port"]

        num_connections = 100
        start_time = time.time()

        connections = []
        for _ in range(num_connections):
            try:
                reader, writer = await asyncio.wait_for(
                    asyncio.open_connection(host, port), timeout=5.0
                )
                connections.append((reader, writer))
            except (asyncio.TimeoutError, OSError):
                pass

        total_time = time.time() - start_time
        rate = num_connections / total_time if total_time > 0 else 0

        print(f"\n连接建立速率: {rate:.2f} 连接/秒")

        # 清理
        for reader, writer in connections:
            writer.close()
            await writer.wait_closed()

        # 验证
        assert (
            rate >= CONCURRENT_TARGETS["connections_per_sec"]
        ), f"连接建立速率 {rate:.2f} 低于目标 {CONCURRENT_TARGETS['connections_per_sec']} 连接/秒"


# ===== 连接池测试 =====


@pytest.mark.benchmark
class TestConnectionPool:
    """连接池测试"""

    async def test_connection_reuse(self, echo_server: dict[str, Any]):
        """
        测试连接复用性能

        复用连接应该比新建连接快得多
        """
        host = echo_server["host"]
        port = echo_server["port"]

        # 测试新建连接时间
        new_conn_times = []
        for _ in range(10):
            start = time.time()
            reader, writer = await asyncio.open_connection(host, port)
            new_conn_times.append(time.time() - start)
            writer.close()
            await writer.wait_closed()

        # 测试复用连接时间 (使用现有连接发送数据)
        reader, writer = await asyncio.open_connection(host, port)
        reuse_times = []
        for _ in range(10):
            start = time.time()
            writer.write(b"ping")
            await writer.drain()
            await reader.read(4)
            reuse_times.append(time.time() - start)
        writer.close()
        await writer.wait_closed()

        avg_new = statistics.mean(new_conn_times)
        avg_reuse = statistics.mean(reuse_times)

        print(f"\n新建连接平均时间: {avg_new*1000:.3f}ms")
        print(f"复用连接平均时间: {avg_reuse*1000:.3f}ms")
        print(f"加速比: {avg_new/avg_reuse:.1f}x")

        # 复用应该快至少 10 倍
        assert avg_new > avg_reuse * 10, "连接复用性能提升不足"
